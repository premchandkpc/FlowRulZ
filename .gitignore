*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Rust
runtime/target/
runtime/Cargo.lock

# Go
server/bin/
server/vendor/
go.sum

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.local

# Skills CLI artifacts (global in ~/.config/opencode/skills/)
.agents/
skills-lock.json

# Dependencies
node_modules/

# Internal / non-shipping
.internal/

# Build
flowrulz
*.o
*.so
